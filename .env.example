# Aimighty Embedder Configuration
# Copy this file to .env and adjust values for your setup

# Model settings
MODEL_NAME=aimighty-embedding-4b
HF_MODEL_ID=Qwen/Qwen3-Embedding-4B

# HuggingFace Token (optional, required for gated models)
# HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Server settings
PORT=9997

# OpenVINO iGPU optimization (Meteor Lake - no XMX)
PERFORMANCE_HINT=THROUGHPUT
NUM_STREAMS=2
GPU_ENABLE_LARGE_ALLOCATIONS=YES
INFERENCE_PRECISION_HINT=f16

# Memory management
MALLOC_ARENA_MAX=1
