# Aimighty OpenVINO Embedder - Environment Configuration

# User/Timezone
PUID=1000
PGID=1000
TZ=Etc/UTC

# Server
MODEL_NAME=aimighty-embedding-4b
HF_MODEL_ID=Qwen/Qwen3-Embedding-4B
PORT=9997

# HuggingFace (optional, for gated models)
HUGGING_FACE_HUB_TOKEN=

# Model Cache
MODEL_CACHE_DIR=/models_cache
OV_CACHE_DIR=/tmp/ov_cache

# OpenVINO GPU Configuration
# OV_DEVICE: GPU for iGPU acceleration, CPU for CPU-only
OV_DEVICE=GPU
# PERFORMANCE_HINT: THROUGHPUT for batch processing, LATENCY for single requests
PERFORMANCE_HINT=THROUGHPUT
# NUM_STREAMS: Parallel execution streams (2 recommended for Arc GPU)
NUM_STREAMS=2
# INFERENCE_PRECISION_HINT: f16 for iGPU, f32 for CPU
INFERENCE_PRECISION_HINT=f16
# GPU_ENABLE_LARGE_ALLOCATIONS: YES to remove 4.2GB unified memory limit
GPU_ENABLE_LARGE_ALLOCATIONS=YES

# Memory Optimization
MALLOC_ARENA_MAX=1